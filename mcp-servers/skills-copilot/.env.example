# Skills Hub MCP Server Configuration

# skills.sh (public skills) — no configuration needed

# PostgreSQL connection (for private skills)
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://localhost:5432/skills

# Local cache path (defaults to ~/.claude/skills-cache)
CACHE_PATH=~/.claude/skills-cache

# Cache TTL in days (default 7)
CACHE_TTL_DAYS=7

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Local skills fallback path (for git-synced skills)
LOCAL_SKILLS_PATH=./.claude/skills
